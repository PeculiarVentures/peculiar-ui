{
  "name": "@peculiar/color",
  "version": "1.8.10",
  "private": false,
  "description": "Library for color manipulation and conversion in JavaScript.",
  "keywords": [
    "color",
    "hex",
    "hsb",
    "palette",
    "rgb"
  ],
  "license": "MIT",
  "author": "PeculiarVentures Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeculiarVentures/peculiar-ui",
    "directory": "packages/color"
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "typings": "dist/types/index.d.ts",
  "esnext": "dist/esnext/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "npm run clean",
    "build": "npm run build:esm && npm run build:cjs && npm run build:esnext",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.build.json -m commonjs --outDir dist/cjs",
    "build:esnext": "tsc -p tsconfig.build.json -t esnext --outDir dist/esnext",
    "clean": "rimraf public dist",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:types": "tsc --noEmit -p tsconfig.build.json"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.x"
  }
}

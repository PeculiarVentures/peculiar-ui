{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "unicorn", "oxc", "react", "jsx-a11y", "vitest"],
  "ignorePatterns": ["public/**", "dist/**", "coverage/**", "CHANGELOG.md"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true
  }
}
